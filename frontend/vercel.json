{
  "builds": [
    {
      "src": "backend/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/backend/:path*.py"
    }
  ],
  "crons": [
  {
    "path": "/api/traffic_api",
    "schedule": "*/15 * * * *"
  }
]
}